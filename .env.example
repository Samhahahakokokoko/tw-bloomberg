# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ADMIN_API_TOKEN=replace_with_a_long_random_admin_token
ADMIN_LINE_UID=your_admin_line_user_id

# Auto-Improve（選填，沒設定則只用 Railway CLI）
RAILWAY_TOKEN=your_railway_api_token
RAILWAY_PROJECT_ID=your_project_id
RAILWAY_SERVICE_ID=your_service_id
DATABASE_URL=sqlite+aiosqlite:///./data/bloomberg.db

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Post-push health check（Hook 自動檢查用）
RAILWAY_BACKEND_URL=https://your-app.railway.app
