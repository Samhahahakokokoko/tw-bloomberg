# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ADMIN_API_TOKEN=replace_with_a_long_random_admin_token
ADMIN_LINE_UID=your_admin_line_user_id

# Railway 部署資訊
RAILWAY_TOKEN=your_railway_api_token
RAILWAY_PROJECT_ID=your_project_id
RAILWAY_SERVICE_ID=your_service_id
RAILWAY_BACKEND_URL=https://your-app.railway.app
DATABASE_URL=sqlite+aiosqlite:///./data/bloomberg.db

# 對外 HTTPS 網址（LINE 圖片訊息必須 HTTPS）
# Railway 上設為與 RAILWAY_BACKEND_URL 相同值
BASE_URL=https://your-app.railway.app

# 環境識別（production / development）
# 設為 production 時，Kill Switch 與 Mock 防護才會完整啟用
ENV=production

# 靜態檔案目錄（圖表/報告 PNG，Railway 上使用預設即可）
# STATIC_DIR=/app/static/reports

# 量化資料庫（選填，不設則使用主 DATABASE_URL）
# QUANT_DB_URL=postgresql+asyncpg://user:pass@host/quant_db

# 安全模式（設為 1 可大幅減少 LINE 推播頻率，避免超額）
LINE_QUOTA_SAFE_MODE=0

# FinMind API（選填，提供更豐富的台股資料）
# FINMIND_TOKEN=your_finmind_token

# Fugle 交易 API（選填，啟用真實下單功能）
# FUGLE_API_KEY=your_fugle_api_key
# FUGLE_API_SECRET=your_fugle_api_secret
# FUGLE_ACCOUNT=your_fugle_account

# YouTube API（選填，法說會影片索引）
# YOUTUBE_API_KEY=your_youtube_api_key

# Frontend
VITE_API_BASE_URL=http://localhost:8000
